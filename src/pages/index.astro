<meta name="twitter:title" content={`経営会議を"報告"から"意思決定"へ｜経営管理OS - ${COMPANY_NAME_EN}`}>
<meta name="twitter:description" content="上場企業並みの管理体制を、中小企業の規模とコストで。外部CFOが、貴社の経営管理OSを構築・伴走します。">
<meta name="twitter:image" content={`${SITE_URL}/ogp.png`}>
<meta name="twitter:image:alt" content={`経営会議を「報告」から「意思決定」へ。中小企業のための経営管理OS｜${COMPANY_NAME}`}>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Zen+Kaku+Gothic+New:wght@500;700;900&display=swap" rel="stylesheet">
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${CORP_URL}/#organization`,
      "name": COMPANY_NAME,
      "alternateName": COMPANY_NAME_EN,
      "url": `${CORP_URL}/`,
    },
    {
      "@type": "WebSite",
      "@id": `${SITE_URL}/#website`,
      "url": `${SITE_URL}/`,
      "name": "経営管理OS｜CIZA",
      "inLanguage": "ja",
      "publisher": { "@id": `${CORP_URL}/#organization` }
    },
    {
      "@type": "Service",
      "name": "経営管理OS構築支援",
      "serviceType": "経営管理体制構築コンサルティング",
      "provider": { "@id": `${CORP_URL}/#organization` },
      "areaServed": "JP",
      "description": "社長の意思決定から逆算して、KPI・レポート・会議・データの流れを設計し、上場企業に耐えうる管理体制を自社仕様・段階的に構築する外部CFO型の伴走支援。",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "経営管理OS 支援プラン",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "財務顧問" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "経営管理OS構築支援" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "外部推進リーダー" } }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "大規模なシステム導入が必要ですか？", "acceptedAnswer": { "@type": "Answer", "text": "既存のExcel/Google Workspace/会計システムを最大限活用します。段階実装で大規模投資は避けます。" } },
        { "@type": "Question", "name": "社内に詳しい人材がいなくても大丈夫ですか？", "acceptedAnswer": { "@type": "Answer", "text": "窓口担当を1名決めていただければ、設計・実装のPMはこちらが担います。" } },
        { "@type": "Question", "name": "AI導入が目的のサービスですか？", "acceptedAnswer": { "@type": "Answer", "text": "いいえ。先に意思決定と管理の設計を行い、その実現手段としてExcel・SaaS・AIなど適切なツールを使います。AIありきではなく、貴社にとって最適な手段を選びます。" } },
        { "@type": "Question", "name": "費用はどのくらいかかりますか？", "acceptedAnswer": { "@type": "Answer", "text": "財務顧問15万円〜、経営管理OS構築支援30万円〜です。6か月区切りで見直し可能です。" } },
        { "@type": "Question", "name": "どんな会社が向いていますか？", "acceptedAnswer": { "@type": "Answer", "text": "部門が複数あり、投資判断が発生し、幹部はいるが数字にはやや弱い、成長・改善を数字で進めたい中小・中堅企業に向いています。" } },
        { "@type": "Question", "name": "業界の成功事例は教えてもらえますか？", "acceptedAnswer": { "@type": "Answer", "text": "事例の紹介より、貴社に合わせた設計を重視します。先を走る会社ほど、借り物の事例より自社仕様の仕組みが必要です。" } },
        { "@type": "Question", "name": "補助金の活用も相談できますか？", "acceptedAnswer": { "@type": "Answer", "text": "可能です。投資判断と一体で助言します。" } }
      ]
    }
  ]
})}></script>
<style>
:root{--ink:#0b0b0c;--ink2:#1a1a1d;--bg:#fff;--bg2:#f7f7f8;--bg3:#fafaf9;--border:#eaeaea;--border2:#d4d4d8;--muted:#6b6b70;--muted2:#98989e;--accent:#94c74c;--accent2:#709f2c;--accent-light:#b1d383;--accent-soft:#ecf1e4;--deep:#0e0e10;--deep2:#1a1a1d;--claude:#a2cc65;--radius:14px;--radius-lg:20px;--max:1200px;--shadow-sm:0 1px 2px rgba(0,0,0,.04),0 1px 3px rgba(0,0,0,.06);--shadow-md:0 4px 12px rgba(0,0,0,.05),0 2px 4px rgba(0,0,0,.04);--shadow-lg:0 20px 50px -12px rgba(0,0,0,.08),0 8px 20px -8px rgba(0,0,0,.06);--shadow-glow:0 20px 60px -15px rgba(148,199,76,.35);}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{font-size:16px;scroll-behavior:smooth;}
body{font-family:'Noto Sans JP','Meiryo','Hiragino Kaku Gothic ProN',sans-serif;color:var(--ink);background:var(--bg);-webkit-font-smoothing:antialiased;overflow-x:hidden;}
h1,h2,h3,h4,.price-title,.nav-brand .brand-text,.mark{font-family:'Zen Kaku Gothic New','Noto Sans JP','Meiryo',sans-serif;}
img{max-width:100%;display:block;}
a{color:inherit;text-decoration:none;}

.w{max-width:var(--max);margin:0 auto;padding:0 24px;}
.sec{padding:96px 0;}
.sec-label{display:block;position:relative;padding-left:15px;font-size:15px;font-weight:800;letter-spacing:.04em;color:var(--accent);margin-bottom:14px;}
.sec-label::before{content:'';position:absolute;left:0;top:1px;bottom:1px;width:3px;border-radius:2px;background:var(--accent);}
.sec h2{font-size:clamp(26px,4vw,42px);font-weight:900;line-height:1.25;letter-spacing:-.015em;}
.sec .lead{color:var(--muted);margin-top:14px;max-width:640px;line-height:1.85;font-size:17px;}
.sec .lead strong{color:var(--ink);font-weight:700;}
.dark .sec-label::before{background:var(--claude);}

.nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(255,255,255,.72);backdrop-filter:blur(20px) saturate(180%);-webkit-backdrop-filter:blur(20px) saturate(180%);border-bottom:1px solid rgba(234,234,234,.6);height:64px;display:flex;align-items:center;transition:all .3s;}
.nav.scrolled{background:rgba(255,255,255,.92);border-bottom-color:var(--border);box-shadow:var(--shadow-sm);}
.nav .w{display:flex;align-items:center;justify-content:space-between;width:100%;}
.nav-brand{display:flex;align-items:center;gap:8px;}
.nav-brand .mark{width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,#94c74c,#b1d383);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:15px;}
.nav-brand .brand-text{font-weight:800;font-size:13.5px;letter-spacing:.02em;color:var(--ink);}
.nav-brand .brand-text b{font-weight:900;}
.nav-brand .brand-text small{display:block;font-size:11.5px;color:var(--muted);font-weight:600;letter-spacing:.06em;}
.nav-links{display:flex;gap:26px;font-size:14.5px;font-weight:600;color:var(--muted);}
.nav-links a{position:relative;transition:color .2s;}
.nav-links a:hover{color:var(--ink);}
.nav-links a::after{content:'';position:absolute;left:50%;bottom:-6px;width:0;height:2px;background:var(--accent);transition:all .2s;transform:translateX(-50%);}
.nav-links a:hover::after{width:100%;}
@media(max-width:880px){.nav-links{display:none;}}
.btn{display:inline-flex;align-items:center;gap:6px;font-weight:700;padding:11px 22px;border-radius:10px;font-size:15px;transition:all .2s cubic-bezier(.16,1,.3,1);}
.btn-dark{background:var(--ink);color:#fff;box-shadow:0 4px 14px rgba(0,0,0,.12);}
.btn-dark:hover{background:#1a1a1d;transform:translateY(-1px);box-shadow:0 8px 24px rgba(0,0,0,.18);}
.btn-outline{border:1.5px solid var(--border2);color:var(--ink);background:#fff;}
.btn-outline:hover{border-color:var(--ink);transform:translateY(-1px);}
.btn-gradient{background:linear-gradient(135deg,#94c74c,#b1d383);color:#fff;box-shadow:var(--shadow-glow);}
.btn-gradient:hover{transform:translateY(-1px);box-shadow:0 24px 70px -15px rgba(148,199,76,.5);}

/* Hero */
.hero{padding-top:120px;padding-bottom:80px;position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;top:-20%;right:-10%;width:60%;height:120%;background:radial-gradient(circle at 60% 40%,rgba(177,211,131,.18) 0%,rgba(148,199,76,.10) 25%,transparent 55%);pointer-events:none;z-index:0;}
.hero::after{content:'';position:absolute;top:10%;left:-15%;width:40%;height:80%;background:radial-gradient(circle at 30% 50%,rgba(232,164,114,.12) 0%,transparent 55%);pointer-events:none;z-index:0;}
.hero > .w{position:relative;z-index:1;}
.hero-content{max-width:900px;}
.hero-tag{display:inline-flex;align-items:center;gap:8px;font-size:13px;font-weight:700;letter-spacing:.1em;color:var(--accent);text-transform:uppercase;margin-bottom:22px;padding:6px 14px;background:var(--accent-soft);border:1px solid rgba(148,199,76,.15);border-radius:10px;}
.hero-tag::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--accent);animation:pulse 2s infinite;box-shadow:0 0 0 0 rgba(148,199,76,.4);}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(148,199,76,.4);}70%{box-shadow:0 0 0 8px rgba(148,199,76,0);}100%{box-shadow:0 0 0 0 rgba(148,199,76,0);}}
.hero h1{font-size:clamp(30px,5vw,54px);font-weight:900;line-height:1.35;letter-spacing:-.02em;}
.hero h1 em{font-style:normal;background:linear-gradient(135deg,#94c74c 0%,#b1d383 50%,#94c74c 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.hero-h1-sub{display:block;font-size:clamp(16px,2vw,20px);font-weight:800;color:var(--muted);margin-top:10px;letter-spacing:0;}
.hero-sub{font-size:17.5px;color:var(--muted);margin-top:22px;line-height:1.9;max-width:760px;}
.hero-sub strong{color:var(--ink);font-weight:700;}
.hero-actions{display:flex;gap:12px;margin-top:32px;flex-wrap:wrap;}
.hero-trust{display:flex;flex-direction:row;flex-wrap:wrap;gap:20px;margin-top:32px;}
.hero-trust-item{display:flex;align-items:center;gap:8px;font-size:14px;color:var(--muted);font-weight:500;}
.hero-trust-item svg{width:16px;height:16px;color:var(--accent);flex-shrink:0;}

/* Dark section */
.dark{background:linear-gradient(180deg,var(--deep) 0%,var(--deep2) 100%);color:#fff;}
.dark .sec-label{color:var(--claude);}
.dark .lead{color:rgba(255,255,255,.55);}
.dark h2{color:#fff;}
.dark .lead strong{color:#fff;}

/* Enemy quadrant (共通の敵) */
.enemy-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-top:36px;}
.enemy-card{border:1px solid var(--border);border-radius:var(--radius);padding:28px;background:#fff;transition:all .3s;position:relative;}
.enemy-card:hover{box-shadow:0 12px 40px rgba(0,0,0,.05);transform:translateY(-3px);}
.enemy-num{font-size:13px;font-weight:800;color:var(--accent);letter-spacing:.1em;margin-bottom:12px;}
.enemy-card h3{font-size:19px;font-weight:900;margin-bottom:10px;line-height:1.5;}
.enemy-card p{color:var(--muted);line-height:1.8;font-size:15px;}
.enemy-cross{margin-top:44px;background:linear-gradient(135deg,var(--deep) 0%,var(--deep2) 100%);color:#fff;border-radius:var(--radius-lg);padding:44px 40px;text-align:center;}
.enemy-cross .pill{display:inline-block;background:rgba(148,199,76,.2);color:#b1d383;padding:6px 16px;border-radius:10px;font-size:13px;font-weight:700;letter-spacing:.1em;margin-bottom:18px;}
.enemy-cross h3{font-size:clamp(19px,2.6vw,26px);font-weight:900;line-height:1.6;margin-bottom:14px;}
.enemy-cross h3 em{font-style:normal;color:#b1d383;}
.enemy-cross p{font-size:15px;color:rgba(255,255,255,.6);max-width:620px;margin:0 auto;line-height:1.85;}
@media(max-width:768px){.enemy-grid{grid-template-columns:1fr;}}

/* Pricing */
.price-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:40px;align-items:stretch;}
.price-card{border:1.5px solid var(--border);border-radius:var(--radius-lg);padding:32px 28px;background:#fff;display:flex;flex-direction:column;position:relative;transition:all .3s;}
.price-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg);}
.price-card.hi{border-color:var(--accent);box-shadow:0 20px 50px -15px rgba(148,199,76,.25);transform:scale(1.03);background:linear-gradient(180deg,#fff 0%,var(--accent-soft) 220%);}
.price-badge{position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#94c74c,#b1d383);color:#fff;font-size:13px;font-weight:800;padding:6px 18px;border-radius:10px;box-shadow:0 6px 16px rgba(148,199,76,.35);white-space:nowrap;}
.price-name{font-size:13px;font-weight:700;color:var(--accent);letter-spacing:.08em;margin-bottom:8px;}
.price-title{font-size:21px;font-weight:900;line-height:1.4;margin-bottom:16px;min-height:54px;}
.price-amount{display:flex;align-items:baseline;gap:4px;margin-bottom:20px;}
.price-amount .num{font-size:34px;font-weight:900;letter-spacing:-.02em;}
.price-amount .unit{font-size:14px;font-weight:700;color:var(--muted);}
.price-list{list-style:none;flex:1;margin-bottom:24px;}
.price-list li{display:flex;gap:8px;padding:6px 0;font-size:15px;color:#444;line-height:1.6;}
.price-list li::before{content:'\2713';color:var(--accent);font-weight:700;flex-shrink:0;}
.price-note{margin-top:32px;text-align:center;font-size:13.5px;color:var(--muted);}
@media(max-width:900px){.price-grid{grid-template-columns:1fr;}.price-card.hi{transform:none;}}

/* Symptom cards (売るべき変化) */
.sym-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:36px;}
.sym-card{border:1px solid var(--border);border-radius:var(--radius);padding:22px 18px;background:#fff;transition:all .25s;}
.sym-card:hover{border-color:var(--accent-light);transform:translateY(-3px);box-shadow:var(--shadow-md);}
.sym-num{font-size:12.5px;font-weight:800;color:var(--accent);margin-bottom:10px;letter-spacing:.06em;}
.sym-card p{font-size:15px;font-weight:700;line-height:1.65;color:var(--ink2);}
.sym-promise{margin-top:40px;display:grid;grid-template-columns:repeat(4,1fr);gap:0;border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;}
.sym-promise > div{padding:22px 18px;text-align:center;border-right:1px solid var(--border);}
.sym-promise > div:last-child{border-right:none;}
.sym-promise .before{font-size:13.5px;color:var(--muted2);text-decoration:line-through;}
.sym-promise .arrow{color:var(--accent);font-weight:900;margin:6px 0;}
.sym-promise .after{font-size:14.5px;font-weight:800;color:var(--ink);}
@media(max-width:900px){.sym-grid{grid-template-columns:repeat(2,1fr);} .sym-promise{grid-template-columns:repeat(2,1fr);}}
@media(max-width:560px){.sym-grid{grid-template-columns:1fr;} .sym-promise{grid-template-columns:1fr;} .sym-promise>div{border-right:none;border-bottom:1px solid var(--border);}}

/* Layer pyramid diagram (4レイヤー) */
.layer-diagram{margin-top:40px;}
.ld-svg{width:100%;max-width:600px;height:auto;display:block;margin:0 auto;}
.ld-caption{text-align:center;margin-top:10px;font-size:14.5px;color:rgba(255,255,255,.55);}
.ld-caption strong{color:var(--claude);font-weight:800;}
.layer-legend{margin-top:36px;display:grid;grid-template-columns:repeat(2,1fr);gap:16px 32px;}
.layer-legend .ll-item{font-size:14.5px;line-height:1.8;color:rgba(255,255,255,.6);padding-top:14px;border-top:1px solid rgba(255,255,255,.08);}
.layer-legend .ll-item strong{color:#fff;font-weight:800;display:block;margin-bottom:3px;font-size:15.5px;}
@media(max-width:768px){.layer-legend{grid-template-columns:1fr;}}

/* Before/After qualitative */
.ba-grid{display:grid;grid-template-columns:1fr auto 1fr;gap:20px;align-items:center;margin-top:36px;}
.ba-card{border-radius:var(--radius);padding:28px;}
.ba-card.before{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);}
.ba-card.after{background:linear-gradient(135deg,rgba(148,199,76,.15),rgba(177,211,131,.08));border:1px solid rgba(148,199,76,.3);}
.ba-tag{font-size:16.5px;font-weight:800;letter-spacing:.08em;margin-bottom:14px;}
.ba-card.before .ba-tag{color:rgba(255,255,255,.4);}
.ba-card.after .ba-tag{color:#b1d383;}
.ba-card ul{list-style:none;display:flex;flex-direction:column;gap:10px;}
.ba-card li{font-size:15px;line-height:1.7;color:rgba(255,255,255,.75);}
.ba-card.before li{color:rgba(255,255,255,.5);}
.ba-arrow{font-size:26px;color:var(--claude);font-weight:900;}
@media(max-width:768px){.ba-grid{grid-template-columns:1fr;}.ba-arrow{text-align:center;transform:rotate(90deg);}}

/* Showcase */
.show-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:36px;}
.show-card{display:block;border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;background:#fff;text-decoration:none;color:inherit;transition:all .25s;box-shadow:var(--shadow-sm);}
.show-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg);border-color:var(--accent-light);}
.show-thumb{aspect-ratio:16/10;overflow:hidden;background:var(--bg2);border-bottom:1px solid var(--border);}
.show-thumb img{width:100%;height:100%;object-fit:cover;object-position:top;display:block;transition:transform .4s;}
.show-card:hover .show-thumb img{transform:scale(1.04);}
.show-body{padding:16px 18px 18px;}
.show-card h4{font-size:16.5px;font-weight:800;margin-bottom:4px;line-height:1.5;}
.show-card .show-hint{font-size:12.5px;color:var(--accent);font-weight:600;}
@media(max-width:900px){.show-grid{grid-template-columns:1fr;}}

/* Flow */
.flow{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-top:40px;counter-reset:step;position:relative;}
.flow::before{content:'';position:absolute;top:56px;left:10%;right:10%;height:2px;background:repeating-linear-gradient(90deg,var(--border2) 0,var(--border2) 6px,transparent 6px,transparent 14px);z-index:0;}
.flow-s{background:#fff;border:1px solid var(--border);border-radius:16px;padding:32px 20px 24px;text-align:center;counter-increment:step;transition:all .3s;position:relative;z-index:1;}
.flow-s:hover{border-color:var(--accent);transform:translateY(-4px);box-shadow:var(--shadow-md);}
.flow-s::before{content:counter(step);display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;font-size:17px;font-weight:900;color:#fff;background:linear-gradient(135deg,#94c74c,#b1d383);border-radius:50%;margin-bottom:14px;box-shadow:0 8px 20px rgba(148,199,76,.25);}
.flow-s h4{font-size:17px;font-weight:900;margin-bottom:6px;letter-spacing:-.005em;}
.flow-s .flow-period{font-size:12.5px;color:var(--accent);font-weight:700;margin-bottom:6px;}
.flow-s p{font-size:14px;color:var(--muted);line-height:1.7;}
@media(max-width:900px){.flow{grid-template-columns:repeat(2,1fr);}.flow::before{display:none;}}
@media(max-width:560px){.flow{grid-template-columns:1fr;}}

/* Credentials (選ばれる理由) */
.cred-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-top:36px;}
.cred-card{padding:24px 26px;border:1px solid rgba(255,255,255,.1);border-radius:var(--radius);background:rgba(255,255,255,.02);}
.cred-card .cred-tag{font-size:16px;font-weight:800;color:var(--claude);letter-spacing:.06em;margin-bottom:10px;}
.cred-card p{font-size:15.5px;line-height:1.8;color:rgba(255,255,255,.8);}
@media(max-width:768px){.cred-grid{grid-template-columns:1fr;}}

/* Blog teaser */
.blog-teaser-grid{margin-top:36px;display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;}
.blog-teaser-card{display:block;border:1px solid var(--border);border-radius:var(--radius-lg);padding:26px 28px;background:#fff;transition:all .25s;}
.blog-teaser-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-lg);border-color:var(--accent-light);}
.bt-date{font-size:12.5px;font-weight:700;color:var(--accent);letter-spacing:.04em;margin-bottom:10px;}
.blog-teaser-card h4{font-size:18px;font-weight:900;line-height:1.5;margin-bottom:8px;}
.blog-teaser-card p{font-size:14.5px;color:var(--muted);line-height:1.8;}
.bt-more{display:inline-block;margin-top:12px;font-size:13.5px;font-weight:700;color:var(--accent);}

/* FAQ */
.faq{border-bottom:1px solid var(--border);}
.faq summary{display:flex;justify-content:space-between;align-items:center;cursor:pointer;list-style:none;padding:22px 4px;font-size:17.5px;font-weight:700;transition:color .2s;gap:16px;}
.faq summary:hover{color:var(--accent);}
.faq summary::-webkit-details-marker{display:none;}
.faq summary::after{content:'';flex-shrink:0;width:28px;height:28px;border-radius:50%;background:var(--bg2);display:inline-flex;align-items:center;justify-content:center;font-size:16px;color:var(--ink);transition:all .3s;background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='%23111' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><line x1='12' y1='5' x2='12' y2='19'/><line x1='5' y1='12' x2='19' y2='12'/></svg>");background-position:center;background-repeat:no-repeat;}
.faq[open] summary::after{transform:rotate(45deg);background-color:var(--accent-soft);}
.faq p{padding:0 4px 22px;color:var(--muted);line-height:1.85;font-size:15.5px;}
.faq p strong{color:var(--ink);}

/* CTA */
.cta-sec{text-align:center;padding:120px 24px;position:relative;overflow:hidden;}
.cta-sec::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 60%,rgba(177,211,131,.1) 0%,transparent 60%);pointer-events:none;}
.cta-sec > *{position:relative;z-index:1;}
.cta-sec h2{font-size:clamp(28px,4.4vw,46px);font-weight:900;line-height:1.35;letter-spacing:-.02em;}
.cta-sec h2 em{font-style:normal;background:linear-gradient(135deg,#94c74c,#b1d383);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.cta-sec .lead{margin:20px auto 0;text-align:center;max-width:520px;}

/* Footer */
.footer{border-top:1px solid var(--border);padding:40px 0;display:grid;grid-template-columns:auto 1fr auto;gap:24px;align-items:center;}
.footer-logos{display:flex;align-items:center;gap:10px;}
.footer-nav{display:flex;justify-content:center;gap:22px;font-size:14px;color:var(--muted);flex-wrap:wrap;}
.footer-nav a:hover{color:var(--ink);}
.footer small{font-size:13px;color:var(--muted2);justify-self:end;}
@media(max-width:768px){
  .footer{grid-template-columns:1fr;text-align:center;gap:20px;padding:32px 0 36px;}
  .footer-logos{justify-content:center;}
  .footer-nav{flex-wrap:wrap;justify-content:center;gap:12px 18px;font-size:13px;row-gap:10px;}
  .footer small{justify-self:center;font-size:12px;}
}

/* Reveal */
.rv{opacity:0;transform:translateY(30px);transition:all .6s cubic-bezier(.16,1,.3,1);}
.rv.v{opacity:1;transform:none;}
.no-reveal .rv{opacity:1!important;transform:none!important;}

@media(max-width:1100px){.price-grid{gap:16px;}}
@media(max-width:900px){
  .sec{padding:60px 0;}
  .enemy-grid{gap:14px;}
  .ld-svg{max-width:440px;}
}
@media(max-width:768px){
  .hero{padding-top:96px;padding-bottom:48px;}
  .cta-sec{padding:60px 16px;}
  h2{font-size:24px!important;}
}
</style>
</head>
