<link rel="canonical" href={`${SITE_URL}/`}>
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%230e0e10'/%3E%3Ctext x='32' y='42' font-family='Arial,sans-serif' font-size='30' font-weight='900' fill='%2394c74c' text-anchor='middle'%3EC%3C/text%3E%3C/svg%3E">
