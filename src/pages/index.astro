---
import { getCollection } from 'astro:content';
const latestPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
).slice(0, 3);
function formatPostDate(d: Date) {
  return `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;
}
// ── グローバル設定（【要決定】項目は仮値。差し替えはここ1箇所でOK） ──────────
const COMPANY_NAME = "株式会社シザコンサルティング";
const COMPANY_NAME_EN = "CIZA Consulting";
const SITE_URL = "https://keieikanri.ciza.co.jp";
const CORP_URL = "https://www.ciza.co.jp";
const CTA_FORM_URL = "https://forms.gle/5iDPnoXr8HZDqqoe7";
// ブランドカラーは【要決定3】未定のためテンプレ標準の暖色のまま（<style>内 :root の --accent 系4変数）
const X_SHARE_URL = `https://twitter.com/intent/tweet?url=${encodeURIComponent(SITE_URL + '/')}&text=${encodeURIComponent('経営会議を「報告」から「意思決定」へ。中小企業のための経営管理OS')}`;
const FB_SHARE_URL = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(SITE_URL + '/')}`;
---
<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
