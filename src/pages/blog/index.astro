---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { SITE_URL } from '../../lib/site';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(d: Date) {
  return `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;
}
---
<BlogLayout
  title="ブログ｜経営管理OS｜CIZA"
  description="経営管理OSの構築ノウハウ、KPI設計、ツール活用事例などを発信しています。"
  canonicalUrl={`${SITE_URL}/blog`}
>
  <main class="sec"><div class="w" style="max-width:900px;">
    <div class="sec-label">お知らせ</div>
    <h2>ブログ</h2>
    <p class="lead">経営管理OSの構築ノウハウ、KPI設計、ツール活用事例などをお届けします。</p>

    <div class="post-list">
      {posts.map((post) => (
        <a class="post-card" href={`/blog/${post.id}`}>
          <div class="post-date">{formatDate(post.data.date)}</div>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
          <span class="post-more">続きを読む &rarr;</span>
        </a>
      ))}
    </div>
  </div></main>

  <style>
    .sec{padding:140px 0 96px;}
    .sec-label{display:block;position:relative;padding-left:15px;font-size:15px;font-weight:800;letter-spacing:.04em;color:var(--accent);margin-bottom:14px;}
    .sec-label::before{content:'';position:absolute;left:0;top:1px;bottom:1px;width:3px;border-radius:2px;background:var(--accent);}
    .sec h2{font-family:'Zen Kaku Gothic New','Noto Sans JP','Meiryo',sans-serif;font-size:clamp(26px,4vw,38px);font-weight:900;line-height:1.25;letter-spacing:-.015em;}
    .sec .lead{color:var(--muted);margin-top:14px;max-width:640px;line-height:1.85;font-size:17px;}
    .post-list{margin-top:44px;display:flex;flex-direction:column;gap:20px;}
    .post-card{display:block;border:1px solid var(--border);border-radius:var(--radius-lg);padding:28px 30px;background:#fff;transition:all .25s;}
    .post-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-lg);border-color:var(--accent-light);}
    .post-date{font-size:13px;font-weight:700;color:var(--accent);letter-spacing:.04em;margin-bottom:10px;}
    .post-card h3{font-family:'Zen Kaku Gothic New','Noto Sans JP','Meiryo',sans-serif;font-size:21px;font-weight:900;line-height:1.5;margin-bottom:10px;}
    .post-card p{font-size:15px;color:var(--muted);line-height:1.8;}
    .post-more{display:inline-block;margin-top:14px;font-size:14px;font-weight:700;color:var(--accent);}
    @media(max-width:768px){.sec{padding:112px 0 60px;} .post-card{padding:22px 20px;}}
  </style>
</BlogLayout>
