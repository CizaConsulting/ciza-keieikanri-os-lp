---
import { COMPANY_NAME, COMPANY_NAME_EN, SITE_URL, CTA_FORM_URL } from '../lib/site';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  jsonLd?: object;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage = `${SITE_URL}/ogp.png`,
  ogType = 'website',
  jsonLd,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="format-detection" content="telephone=no">
<meta name="theme-color" content="#0b0b0c">
<meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1">
<meta name="author" content={COMPANY_NAME}>
<link rel="canonical" href={canonicalUrl}>
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%230e0e10'/%3E%3Ctext x='32' y='42' font-family='Arial,sans-serif' font-size='30' font-weight='900' fill='%2394c74c' text-anchor='middle'%3EC%3C/text%3E%3C/svg%3E">
<title>{title}</title>
<meta name="description" content={description}>
<meta property="og:type" content={ogType}>
<meta property="og:site_name" content={COMPANY_NAME}>
<meta property="og:locale" content="ja_JP">
<meta property="og:url" content={canonicalUrl}>
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:image" content={ogImage}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:type" content="image/png">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={ogImage}>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&family=Zen+Kaku+Gothic+New:wght@500;700;900&display=swap" rel="stylesheet">
{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>}
<style>
:root{--ink:#0b0b0c;--ink2:#1a1a1d;--bg:#fff;--bg2:#f7f7f8;--bg3:#fafaf9;--border:#eaeaea;--border2:#d4d4d8;--muted:#6b6b70;--muted2:#98989e;--accent:#94c74c;--accent2:#709f2c;--accent-light:#b1d383;--accent-soft:#ecf1e4;--deep:#0e0e10;--deep2:#1a1a1d;--claude:#a2cc65;--radius:14px;--radius-lg:20px;--max:1200px;--shadow-sm:0 1px 2px rgba(0,0,0,.04),0 1px 3px rgba(0,0,0,.06);--shadow-md:0 4px 12px rgba(0,0,0,.05),0 2px 4px rgba(0,0,0,.04);--shadow-lg:0 20px 50px -12px rgba(0,0,0,.08),0 8px 20px -8px rgba(0,0,0,.06);--shadow-glow:0 20px 60px -15px rgba(148,199,76,.35);}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{font-size:16px;scroll-behavior:smooth;}
body{font-family:'Noto Sans JP','Meiryo','Hiragino Kaku Gothic ProN',sans-serif;color:var(--ink);background:var(--bg);-webkit-font-smoothing:antialiased;overflow-x:hidden;}
h1,h2,h3,h4,.nav-brand .brand-text,.mark{font-family:'Zen Kaku Gothic New','Noto Sans JP','Meiryo',sans-serif;}
img{max-width:100%;display:block;}
a{color:inherit;text-decoration:none;}
.w{max-width:var(--max);margin:0 auto;padding:0 24px;}

.nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(255,255,255,.72);backdrop-filter:blur(20px) saturate(180%);-webkit-backdrop-filter:blur(20px) saturate(180%);border-bottom:1px solid rgba(234,234,234,.6);height:64px;display:flex;align-items:center;transition:all .3s;}
.nav.scrolled{background:rgba(255,255,255,.92);border-bottom-color:var(--border);box-shadow:var(--shadow-sm);}
.nav .w{display:flex;align-items:center;justify-content:space-between;width:100%;}
.nav-brand{display:flex;align-items:center;gap:8px;}
.nav-brand .mark{width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,#94c74c,#b1d383);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:15px;}
.nav-brand .brand-text{font-weight:800;font-size:13.5px;letter-spacing:.02em;color:var(--ink);}
.nav-brand .brand-text small{display:block;font-size:11.5px;color:var(--muted);font-weight:600;letter-spacing:.06em;}
.nav-links{display:flex;gap:26px;font-size:14.5px;font-weight:600;color:var(--muted);}
.nav-links a{position:relative;transition:color .2s;}
.nav-links a:hover{color:var(--ink);}
.nav-links a::after{content:'';position:absolute;left:50%;bottom:-6px;width:0;height:2px;background:var(--accent);transition:all .2s;transform:translateX(-50%);}
.nav-links a:hover::after{width:100%;}
@media(max-width:880px){.nav-links{display:none;}}
.btn{display:inline-flex;align-items:center;gap:6px;font-weight:700;padding:11px 22px;border-radius:10px;font-size:15px;transition:all .2s cubic-bezier(.16,1,.3,1);}
.btn-dark{background:var(--ink);color:#fff;box-shadow:0 4px 14px rgba(0,0,0,.12);}
.btn-dark:hover{background:#1a1a1d;transform:translateY(-1px);box-shadow:0 8px 24px rgba(0,0,0,.18);}
.btn-outline{border:1.5px solid var(--border2);color:var(--ink);background:#fff;}
.btn-outline:hover{border-color:var(--ink);transform:translateY(-1px);}
.btn-gradient{background:linear-gradient(135deg,#94c74c,#b1d383);color:#fff;box-shadow:var(--shadow-glow);}
.btn-gradient:hover{transform:translateY(-1px);box-shadow:0 24px 70px -15px rgba(148,199,76,.5);}

/* Footer */
.footer{border-top:1px solid var(--border);padding:40px 0;display:grid;grid-template-columns:auto 1fr auto;gap:24px;align-items:center;}
.footer-logos{display:flex;align-items:center;gap:10px;}
.footer-nav{display:flex;justify-content:center;gap:22px;font-size:14px;color:var(--muted);flex-wrap:wrap;}
.footer-nav a:hover{color:var(--ink);}
.footer small{font-size:13px;color:var(--muted2);justify-self:end;}
@media(max-width:768px){
  .footer{grid-template-columns:1fr;text-align:center;gap:20px;padding:32px 0 36px;}
  .footer-logos{justify-content:center;}
  .footer-nav{flex-wrap:wrap;justify-content:center;gap:12px 18px;font-size:13px;row-gap:10px;}
  .footer small{justify-self:center;font-size:12px;}
}
</style>
<slot name="head-extra" />
</head>
<body>

<nav class="nav"><div class="w">
  <a href="/" class="nav-brand">
    <div class="mark">C</div>
    <div class="brand-text">CIZA<small>経営管理OS</small></div>
  </a>
  <div class="nav-links">
    <a href="/#services">サービス</a>
    <a href="/#why">選ばれる理由</a>
    <a href="/blog">ブログ</a>
    <a href="/#faq">FAQ</a>
  </div>
  <a href={CTA_FORM_URL} target="_blank" rel="noopener noreferrer" class="btn btn-dark">無料で経営管理診断を受ける &rarr;</a>
</div></nav>

<slot />

<footer><div class="w footer">
  <div class="footer-logos">
    <div class="mark" style="width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,#94c74c,#b1d383);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:14px;">C</div>
    <span style="font-size:13.5px;color:var(--muted);font-weight:600;letter-spacing:.02em;">経営管理OS｜CIZA</span>
  </div>
  <div class="footer-nav">
    <a href="/#services">サービス</a>
    <a href="/#why">選ばれる理由</a>
    <a href="/blog">ブログ</a>
    <a href="/#faq">FAQ</a>
    <a href={CTA_FORM_URL} target="_blank" rel="noopener noreferrer">お問い合わせ</a>
    <a href="https://www.ciza.co.jp/company.html" target="_blank" rel="noopener noreferrer">会社概要</a>
    <a href="/privacy">プライバシーポリシー</a>
  </div>
  <small>&copy; 2026 {COMPANY_NAME_EN}</small>
</div></footer>

<script>
const nav = document.querySelector('.nav');
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 20);
}, { passive: true });
</script>
</body>
</html>
